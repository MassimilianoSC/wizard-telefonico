# Variabili d'ambiente — copia in .env e compila i valori reali.
# Il .env NON va committato (è in .gitignore).

DEFAULT_TENANT_ID=pizzeria-demo

# --- Twilio (Console: Account SID + Auth Token) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Google / Gemini (Vertex AI) ---
# Autenticazione via ADC: `gcloud auth application-default login` (nessuna chiave).
GOOGLE_CLOUD_PROJECT=wizard-telefonico
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-live-2.5-flash-native-audio
GEMINI_VOICE=Kore
GEMINI_LANGUAGE=it-IT

# --- Telefonia ---
# Host pubblico SENZA schema (ngrok in dev, Cloud Run in prod). In dev può restare
# vuoto: viene dedotto dall'header Host della richiesta Twilio.
SERVICE_HOST=
